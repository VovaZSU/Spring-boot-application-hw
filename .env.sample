# MySQL Configuration (Data for the database container)
MYSQLDB_USER=root
MYSQLDB_ROOT_PASSWORD=your_secure_password_here
MYSQLDB_DATABASE=test
MYSQLDB_LOCAL_PORT=3307
MYSQLDB_DOCKER_PORT=3306

# Spring Boot Configuration (Ports)
SPRING_LOCAL_PORT=8080
SPRING_DOCKER_PORT=8080

# Security (JWT)
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRATION=30000